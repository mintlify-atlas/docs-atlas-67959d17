  "keyFeatures": [
    "AES-256-GCM encryption with per-secret salts and IVs",
    "Role-based access control (admin/member)",
    "Team-based secret sharing",
    "Comprehensive audit logging",
    "CLI for command-line workflows",
    "Interactive TUI built with Bubble Tea",
    "Bulk import/export from .env files",
    "Secret versioning and history",
    "Rate limiting (100 req/min per IP)",
    "JWT authentication with 8-hour expiry",
    "Argon2id password hashing",
    "SQLite database with simple deployment"
  ],
  "publicApiSurface": [
    "imitsu register -e <email> -n <name>",
    "imitsu login <email>",
    "imitsu logout",
    "imitsu whoami",
    "imitsu set <name> [value]",
    "imitsu get <name>",
    "imitsu ls",
    "imitsu rm <name>",
    "imitsu share <name> -u <email>",
    "imitsu share-team <secret> <team>",
    "imitsu team create <name>",
    "imitsu team ls",
    "imitsu team add <team> <email>",
    "imitsu team members <team>",
    "imitsu import <file>",
    "imitsu export [file]",
    "imitsu users",
    "imitsu audit",
    "POST /api/auth/register",
    "POST /api/auth/login",
    "GET /api/auth/me",
